# Environment Configuration
# Copy this file to .env and fill in your actual values

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/election_assistant?retryWrites=true&w=majority
DATABASE_NAME=election_assistant

# JWT Authentication
JWT_SECRET_KEY=your_secret_key_here_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Assistant (Grok/xAI)
XAI_API_KEY=your_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
